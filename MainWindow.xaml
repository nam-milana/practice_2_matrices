<Window x:Class="practice_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        Title="Matrix Benchmark - Сравнение алгоритмов"
        Height="850"
        Width="1000">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="1.2*"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal"
                Grid.Row="0"
                Margin="0,0,0,15">
            <Label Content="Размер матрицы:"
                    VerticalAlignment="Center"
                    FontWeight="Bold"/>
            <TextBox x:Name="SizeInput"
                    Text="1000"
                    Width="80"
                    VerticalAlignment="Center"
                    Margin="5,0"
                    Padding="3"/>
            <Button x:Name="RunButton"
                    Content="Запустить тест"
                    Click="OnRunClick"
                    Width="120"
                    Margin="10,0"
                    Background="#007ACC"
                    Foreground="White"
                    BorderThickness="0"/>
            <ProgressBar x:Name="Loader"
                    IsIndeterminate="True"
                    Width="150"
                    Height="20"
                    Visibility="Collapsed"
                    Margin="10,0"/>
        </StackPanel>

        <UniformGrid Grid.Row="1"
                Columns="2">
            <GroupBox Header="Стандартная формула (O(N³))"
                    Margin="5">
                <ScottPlot:WpfPlot x:Name="StandardPlot"/>
            </GroupBox>
            <GroupBox Header="Упрощенная формула (O(N²))"
                    Margin="5">
                <ScottPlot:WpfPlot x:Name="OptimizedPlot"/>
            </GroupBox>
        </UniformGrid>

        <GroupBox Grid.Row="2"
                Header="Общее сравнение всех методов (мс)"
                Margin="5,10,5,5">
            <ScottPlot:WpfPlot x:Name="SummaryPlot"/>
        </GroupBox>
    </Grid>
</Window>